# Copy this file to .env and fill in the values before running docker-compose
# The .env file is excluded from version control.

# PostgreSQL
POSTGRES_DB=OwnDeliveryDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development

# JWT — must be at least 32 characters
JWT_KEY=change_me_use_a_long_random_secret_min_32_chars
JWT_ISSUER=OwnDeliveryApi
JWT_AUDIENCE=OwnDeliveryApi
JWT_EXPIRES_MINUTES=60
